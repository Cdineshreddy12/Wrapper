{
  "mcpServers": {
    "aws-mcp": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata",
        "AWS_REGION=ap-south-1"
      ]
    },
    "kubernetes": {
      "command": "npx",
      "args": [
        "-y",
        "kubernetes-mcp-server@latest"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "supabase": {
      "url": "https://mcp.supabase.com/mcp?project_ref=eysqgnklsaezjinmxsrz",
      "headers": {}
    },
    "supabase2": {
      "url": "https://mcp.supabase.com/mcp?project_ref=bpxridmrgbrywpesptho&features=account%2Cdocs%2Cdebugging%2Cdatabase%2Cdevelopment%2Cfunctions%2Cbranching%2Cstorage",
      "headers": {}
    }
  }
}
